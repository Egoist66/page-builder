{
  "name": "page-builder",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "nuxt dev",
    "dev:host": "nuxt cleanup && nuxt dev --host",
    "dev-https": "nuxt cleanup && nuxt dev --host --https",
    "build:analyze": "nuxt analyze",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "clean": "nuxt cleanup",
    "clean:all": "nuxt cleanup && rimraf node_modules .nuxt .output",
    "upgrade": "nuxt upgrade",
    "upgrade:force": "nuxt upgrade --force"
  },
  "dependencies": {
    "@artmizu/nuxt-prometheus": "3.0.1",
    "@nuxt/hints": "1.0.2",
    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "0.13.2",
    "@nuxt/ui": "4.6.0",
    "@nuxtjs/i18n": "10.2.4",
    "@pinia/nuxt": "0.11.3",
    "@prisma/client": "^7.6.0",
    "@vueuse/nuxt": "14.2.1",
    "nuxt": "^4.4.2",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "prisma": "^7.6.0",
    "rimraf": "^6.1.3",
    "vue-tsc": "^3.2.6"
  }
}
